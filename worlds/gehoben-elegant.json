{
  "$comment": "Charakter-Welt gehoben-elegant — neu entworfen (kein Referenz-Template in diagnose-prototyp.html, dort als 'Welt in Arbeit' markiert)",
  "id": "gehoben-elegant",
  "label": "Gehoben & elegant",
  "tagline": "hier bin ich in exklusiven Händen",
  "design_tokens": {
    "colors": {
      "primary": "#1c2420",
      "primary_dark": "#121712",
      "surface_base": "#f7f4ee",
      "surface_tinted": "#eae4d8",
      "accent": "#a8823f",
      "text": "#1c2420",
      "text_muted": "#6b6a63"
    },
    "fonts": {
      "display": {
        "family": "Cormorant Garamond",
        "google": "Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400",
        "role": "headlines"
      },
      "body": {
        "family": "DM Sans",
        "google": "DM+Sans:wght@300;400;500",
        "role": "body_ui"
      },
      "utility_mono": {
        "family": "IBM Plex Mono",
        "google": "IBM+Plex+Mono",
        "role": "facts_prices_only"
      }
    },
    "radii": {
      "button": "0",
      "card": "0",
      "section_cap": "0"
    },
    "type_scale": {
      "display_clamp": "clamp(2.2rem, 3.6vw, 3.6rem)",
      "display_weight": "300",
      "display_line_height": "1.15",
      "h2": "1.7rem",
      "h2_weight": "300"
    }
  },
  "form_language": {
    "hero": {
      "layout": "centered_symmetric",
      "background": "surface_base",
      "bottom_cap_radius": false,
      "headline_font": "display",
      "cta_shape": "outlined",
      "rule_above_headline": true,
      "text_align": "center",
      "max_width_headline": "26ch"
    },
    "gallery": {
      "layout_bias": "large_single_or_pair",
      "columns": "1fr",
      "gap": "2rem",
      "cell_radius": "0",
      "stagger": false
    },
    "sections": {
      "transition": "fine_line_separators",
      "eyebrow_labels": false,
      "dark_sections": [],
      "contact_style": "tinted_surface",
      "has_marquee": false,
      "section_spacing": "8rem",
      "rhythm": "langsam"
    },
    "freiheitsgrade": {
      "FR1_layout_asymmetry": "zurückhaltend — Seite ist symmetrisch/zentriert angelegt (der Differenzierer zu den anderen drei Welten); keine Versätze, keine Splits",
      "FR2_scale_jumps": "sehr gedämpft — kleine Typo neben viel Weissraum statt Riesen-Sprüngen; Display bleibt kompakt (max. 3.6rem)",
      "FR3_transitions": "ruhig — feine 1px-Hairlines trennen Sektionen statt Farbwechsel; Weissraum ist der Übergang",
      "FR4_held_form": "grosse isolierte Kennzahl auf viel Weissraum, zentriert (Einsamkeit als Inszenierung)",
      "FR5_images": "betont — grosszügige, ruhige Anschnitte einzelner grossformatiger Bilder statt dichter Galerien",
      "FR6_micro": "betont — Hairlines als durchgängiges Ornament, null Radien als Prinzip, Gold/Messing-Akzent sehr sparsam (Buttons, Kennzahl, Trennstriche)"
    },
    "quantity_rules": {
      "quotes": [
        { "min": 0, "max": 0, "layout": "hidden", "overflow": null, "cap": null },
        { "min": 1, "max": null, "layout": "solo_large", "overflow": "discard", "cap": 1 }
      ],
      "gallery_items": [
        { "min": 0, "max": 0, "layout": "hidden", "overflow": null, "cap": null },
        { "min": 1, "max": 3, "layout": "feature_single", "overflow": null, "cap": null },
        { "min": 4, "max": null, "layout": "feature_single", "overflow": "discard", "cap": 3 }
      ],
      "services": [
        { "min": 0, "max": 0, "layout": "hidden", "overflow": null, "cap": null },
        { "min": 1, "max": 4, "layout": "inline_list", "overflow": null, "cap": null },
        { "min": 5, "max": null, "layout": "inline_list", "overflow": "discard", "cap": 4 }
      ],
      "facts": [
        { "min": 0, "max": 0, "layout": "hidden", "overflow": null, "cap": null },
        { "min": 1, "max": 3, "layout": "inline_facts", "overflow": null, "cap": null },
        { "min": 4, "max": null, "layout": "fact_panel", "overflow": "discard", "cap": 3 }
      ]
    }
  }
}
